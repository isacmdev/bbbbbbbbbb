<ui:Window
    x:Class="ControlParental.App.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:Microsoft.UI.Xaml"
    Title="Control Parental">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Progress -->
        <StackPanel Grid.Row="0" Margin="0,24,0,16">
            <TextBlock x:Name="ProgressLabel" FontSize="14" Foreground="#0078D4" FontWeight="SemiBold" Text="{Binding ProgressLabel}" />
            <ProgressBar x:Name="ProgressBar" Height="8" Margin="0,8,0,0" Minimum="0" Maximum="4" Value="{Binding ProgressCount}" Foreground="#0078D4" />
        </StackPanel>

        <!-- Step Title -->
        <TextBlock Grid.Row="1" x:Name="StepTitle" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Foreground="#1A1A1A" Text="{Binding CurrentStep.Title}" />

        <!-- Step Content -->
        <ScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="StepDescription" FontSize="16" TextWrapping="Wrap" Foreground="#666666" Text="{Binding CurrentStep.Description}" />
                <Border x:Name="ActionArea" Margin="0,24,0,0" Padding="16" Background="White">
                    <StackPanel>
                        <TextBlock x:Name="ActionText" FontSize="14" TextWrapping="Wrap" Text="{Binding CurrentStep.ButtonLabel}" />
                        <Button x:Name="ExecuteButton" Content="Ejecutar" Margin="0,16,0,0" Padding="24,12" HorizontalAlignment="Stretch" Background="#0078D4" Foreground="White" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Navigation -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Grid.Column="0" Content="Abandonar" Padding="16,12" HorizontalAlignment="Stretch" />
            <Button x:Name="NextButton" Grid.Column="2" Content="Siguiente" Padding="16,12" HorizontalAlignment="Stretch" IsEnabled="{Binding CanGoNext}" Background="#0078D4" Foreground="White" />
        </Grid>

        <!-- Demo Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="4" x:Name="DemoOverlay" Visibility="Collapsed">
            <Border Background="#E0000000" />
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="¡Tu protección está activa!" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                <TextBlock x:Name="DemoCountdownText" Text="{Binding DemoCountdownText}" FontSize="72" FontWeight="Bold" Foreground="#0078D4" HorizontalAlignment="Center" Margin="0,24,0,0" />
                <TextBlock Text="segundos" FontSize="16" Foreground="#AAAAAA" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:Window>
